            </a:r>
            <a:r>
              <a:rPr lang="zh-TW" altLang="en-US" b="0" dirty="0"/>
              <a:t>適合在台灣中部與南部地區栽種。</a:t>
            </a:r>
          </a:p>
          <a:p>
            <a:r>
